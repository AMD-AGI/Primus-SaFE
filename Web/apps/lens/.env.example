# Lens Frontend Environment Variables
# ============================================================
# .env.development       - Development defaults (tracked by git)
# .env.production        - Production defaults  (tracked by git)
# .env.development.local - Local overrides for sensitive values (NOT tracked by git)
#
# For sensitive values (API keys, SSO secrets, proxy targets, etc.),
# create .env.development.local and add your values there.
# ============================================================

# ---------- Client-side env vars (VITE_ prefix) ----------

# API base URL (default: /v1)
# VITE_API_BASE_URL=/v1

# ---------- SSO / Okta (REQUIRED for SSO login) ----------
# These must be set in .env.development.local or via CI/CD.
# Do NOT commit real values to tracked env files.

# Okta domain (e.g. https://your-org.okta.com)
# VITE_SSO_OKTA_DOMAIN=

# Okta OAuth Client ID
# VITE_SSO_CLIENT_ID=

# Okta authorization endpoint
# VITE_SSO_AUTH_ENDPOINT=

# Okta token endpoint
# VITE_SSO_TOKEN_ENDPOINT=

# ---------- Dev server proxy targets (no VITE_ prefix) ----------
# These configure the Vite dev server reverse proxy.
# Put actual values in .env.development.local.

# Backend target for /lens/v1 and /api/v1 (default: http://localhost:8088)
# PROXY_BACKEND_TARGET=http://localhost:8088

# Lens Agent Chat service target (default: http://localhost:8003)
# PROXY_AGENT_TARGET=http://localhost:8003

# Dev domain for cookie rewriting and allowedHosts (default: localhost)
# PROXY_DEV_DOMAIN=localhost
