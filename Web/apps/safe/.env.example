# Safe Frontend Environment Variables
# ============================================================
# .env.development       - Development defaults (tracked by git)
# .env.production        - Production defaults  (tracked by git)
# .env.development.local - Local overrides for sensitive values (NOT tracked by git)
#
# For sensitive values (API keys, proxy targets, etc.),
# create .env.development.local and add your values there.
# ============================================================

# ---------- Client-side env vars (VITE_ prefix) ----------

# API base URL (default: /api)
# VITE_API_BASE_URL=/api

# Lens API base URL (default: /lens/v1)
# VITE_LENS_BASE_URL=/lens/v1

# Root cause analysis API base URL (default: /root-cause-skills)
# VITE_ROOT_CAUSE_BASE_URL=/root-cause-skills

# MCP server base URL (default: /mcp-proxy)
# VITE_MCP_BASE_URL=/mcp-proxy

# MCP API key for Bearer token authentication
# VITE_MCP_API_KEY=

# Agent WebSocket base URL (default: empty, uses relative path)
# VITE_AGENT_BASE_URL=

# Agent socket.io path (default: /api/v1/agent/ops/socket.io)
# VITE_AGENT_PATH=/api/v1/agent/ops/socket.io

# ---------- Dev server proxy targets (no VITE_ prefix) ----------
# These configure the Vite dev server reverse proxy.
# Put actual values in .env.development.local.

# Main API backend (default: http://localhost:8088)
# PROXY_API_TARGET=http://localhost:8088

# Backend for /lens, /root-cause, /agent/ops (default: same as PROXY_API_TARGET)
# PROXY_BACKEND_TARGET=http://localhost:8088

# PrimusClaw backend for /claw-api (default: same as PROXY_API_TARGET)
# Override this when the main API target runs an older Claw build than the
# environment you actually want to test plugins/tools against.
# PROXY_CLAW_TARGET=http://localhost:8088

# WebSocket backend (default: derived from PROXY_API_TARGET)
# PROXY_WS_TARGET=ws://localhost:8088

# MCP proxy backend (default: same as PROXY_API_TARGET)
# PROXY_MCP_TARGET=http://localhost:8088

# MCP rewrite path prefix (default: /mcp)
# PROXY_MCP_REWRITE_PREFIX=/mcp

# Dev domain for cookie rewriting and allowedHosts (default: localhost)
# PROXY_DEV_DOMAIN=localhost
