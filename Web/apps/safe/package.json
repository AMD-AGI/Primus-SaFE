    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.0",
    "lodash": "^4.17.23",
    "marked": "^17.0.1",
    "pinia": "^3.0.3",
    "pinia-plugin-persistedstate": "^4.5.0",
    "socket.io-client": "^4.8.3",
