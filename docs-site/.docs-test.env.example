# Docs-as-test runtime parameters — TEMPLATE.
#
# Copy this file to `.docs-test.env` (which is gitignored) and fill in your environment.
# The docs-as-test run reads these values; NEVER commit real hosts or credentials.
#
# Console base URL (no trailing slash):
PRIMUS_CONSOLE_URL=https://<your-console-host>
# Seeded admin login as user/password:
PRIMUS_ADMIN_LOGIN=<admin-user>/<admin-password>
